# ─── LinkedIn Agent — Local Development Environment Template ─────────────────
# Copy this file to .env and fill in real values for local testing.
# .env is gitignored — NEVER commit real secrets.
#
# Usage (PowerShell):  Copy-Item .env.example .env
# Usage (bash/mac):    cp .env.example .env
#
# Then install python-dotenv (pip install python-dotenv) and add at the top
# of agent.py or any entry point:
#   from dotenv import load_dotenv; load_dotenv()

# ── Required ──────────────────────────────────────────────────────────────────

# Groq API — get from https://console.groq.com/keys
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# LinkedIn OAuth token — from https://developer.linkedin.com or your token renewal flow
LINKEDIN_ACCESS_TOKEN=AQX...
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXXXX

# Date (YYYY-MM-DD) when the above token was issued — used to track 60-day expiry
LINKEDIN_TOKEN_DATE=2025-01-01

# ── Optional — Token Auto-Refresh ─────────────────────────────────────────────
# LinkedIn Developer App credentials (only needed for auto-refresh via token_manager.py)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REFRESH_TOKEN=

# ── Optional — Notifications ──────────────────────────────────────────────────

# Telegram bot (recommended — easiest to set up)
# 1. Create bot at @BotFather → copy token
# 2. Message @userinfobot → copy your chat_id
# 3. Send your bot a /start message first so it can reply to you
TELEGRAM_BOT_TOKEN=7123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# Email (Gmail SMTP — requires an App Password, not your login password)
# App Passwords: https://myaccount.google.com/apppasswords
NOTIFY_EMAIL=youraddress@gmail.com
NOTIFY_EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
NOTIFY_TO_EMAIL=youraddress@gmail.com

# WhatsApp (CallMeBot free service — https://www.callmebot.com/blog/free-api-whatsapp-messages/)
CALLMEBOT_PHONE=+1XXXXXXXXXX
CALLMEBOT_APIKEY=XXXXXXX

# ── Optional — Author Personalisation ─────────────────────────────────────────
AUTHOR_NAME=Your Name
USER_NAME=Your Name

# ── Optional — GitHub API (for token_manager.py secret updates) ───────────────
# GITHUB_TOKEN is auto-provided in GitHub Actions; only set this locally if needed
# GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GITHUB_REPOSITORY=yourgithubusername/LinkedIn_Content_Update
