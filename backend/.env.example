# Database
DATABASE_URL=postgresql://user:password@localhost:5432/linkedin_generator
# For SQLite dev: DATABASE_URL=sqlite:///./linkedin_generator.db

# API Configuration
PORT=8000
PYTHON_ENV=development
SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# LinkedIn API
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/auth/linkedin/callback

# Groq API (for post generation)
GROQ_API_KEY=your_groq_api_key

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard?success=true
STRIPE_CANCEL_URL=http://localhost:3000/pricing?cancelled=true

# Email (optional for future notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@your-domain.com

# Cloud Storage (optional for diagram storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_s3_bucket_name

# Logging
LOG_LEVEL=INFO
SQL_ECHO=false
